---
import { Image } from "astro:assets";
import Logo from "@assets/images/logo.png";
import Legitec from "@assets/images/legitec.png";
---

<footer class="bg-light relative text-dark py-8 sm:py-12">
    <div class="max-w-5xl mx-auto px-6">
        
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12">
            
            <div class="flex flex-col items-center lg:items-start">
            <a href="/">
                <Image
                    src={Logo}
                    alt="Binding Software Logo"
                    class="w-48 lg:w-52 2xl:w-60 h-auto mb-4"
                    width="3072"
                    height="768"
                    loading="lazy"
                    decoding="async"
                />
            </a>
            <div
                class="flex items-center justify-center sm:justify-start gap-4 sm:gap-6"
            >
                <a
                    rel="noopener noreferrer"
                    target="_blank"
                    href="https://aws.amazon.com/what-is-cloud-computing"
                >
                    <img
                        src="https://d0.awsstatic.com/logos/powered-by-aws.png"
                        alt="Powered by AWS Cloud Computing"
                        class="w-24 sm:w-28 2xl:w-32 h-auto mb-4"
                    />
                </a>
                <Image
                    src={Legitec}
                    alt="Legitec Certification"
                    class="w-40 sm:w-20 2xl:w-24 h-auto mb-4"
                    width="721"
                    height="664"
                    loading="lazy"
                    decoding="async"
                />
            </div>
        </div>
        <div class="text-center sm:text-left">
            <h3
                class="text-sm sm:text-base 2xl:text-lg font-semibold text-dark mb-2 2xl:mb-4"
            >
                Enlaces Rápidos
            </h3>
            <nav
                class="flex flex-col space-y-2 flex-wrap text-xs sm:text-sm 2xl:text-base "
            >
                <a
                    href="/es/"
                    class="hover:text-blue-500 transition-colors"
                    >Inicio</a
                >
                <a
                    href="/es/solutions/identity"
                    class="hover:text-blue-500 transition-colors"
                    >Binding Identity</a
                >
                <a
                    href="/es/solutions/phone"
                    class="hover:text-blue-500 transition-colors"
                    >Binding Phone</a
                >
                <a
                    href="/es/partners"
                    class="hover:text-blue-500 transition-colors"
                    >Partners</a
                >
                <a
                    href="/es/training"
                    class="hover:text-blue-500 transition-colors"
                    >Training</a
                >
                <a
                    href="/es/idi"
                    class="hover:text-blue-500 transition-colors"
                    >I+D+i</a
                >
                <a
                    href="/es/legal"
                    class="hover:text-blue-500 transition-colors"
                    >Aviso Legal</a
                >
                <a
                    href="/es/cookies"
                    class="hover:text-blue-500 transition-colors"
                    >Cookies</a
                >
            </nav>
        </div>
        <div class="text-center sm:text-left">
            <h3
                class="text-sm sm:text-base 2xl:text-lg font-semibold text-dark mb-2 2xl:mb-4"
            >
                Contacto
            </h3>
            <p class="text-xs sm:text-sm 2xl:text-base">
                Email: sales@bindingsoftware.com
            </p>
            <p class="text-xs sm:text-sm 2xl:text-base">
                Dirección: El Salvador 10, Molina de Segura, Spain
            </p>
        </div>
        <div class="text-center sm:text-left">
            <h3
                class="text-sm sm:text-base 2xl:text-lg font-semibold text-dark mb-2 2xl:mb-4"
            >
                Redes Sociales
            </h3>
            <div class="flex justify-center lg:justify-start">
                <a
                    href="https://www.linkedin.com/company/binding-software/"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="LinkedIn"
                    class="text-2xl hover:text-secondary transition-colors"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        x="0px"
                        y="0px"
                        width="36"
                        height="36"
                        viewBox="0 0 48 48"
                    >
                        <path
                            fill="#0288D1"
                            d="M42,37c0,2.762-2.238,5-5,5H11c-2.761,0-5-2.238-5-5V11c0-2.762,2.239-5,5-5h26c2.762,0,5,2.238,5,5V37z"
                        ></path><path
                            fill="#FFF"
                            d="M12 19H17V36H12zM14.485 17h-.028C12.965 17 12 15.888 12 14.499 12 13.08 12.995 12 14.514 12c1.521 0 2.458 1.08 2.486 2.499C17 15.887 16.035 17 14.485 17zM36 36h-5v-9.099c0-2.198-1.225-3.698-3.192-3.698-1.501 0-2.313 1.012-2.707 1.99C24.957 25.543 25 26.511 25 27v9h-5V19h5v2.616C25.721 20.5 26.85 19 29.738 19c3.578 0 6.261 2.25 6.261 7.274L36 36 36 36z"
                        ></path>
                    </svg>
                </a>
            </div>
        </div>
    </div>
    <div
        class="mt-8 sm:mt-12 pt-6 sm:pt-8 border-t border-dark text-center"
    >
        <p class="text-xs sm:text-sm 2xl:text-base">
            &copy; 2026 Binding Software. All rights reserved.
        </p>
    </div>
</div>
</footer>