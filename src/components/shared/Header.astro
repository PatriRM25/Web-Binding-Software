---
import { Image } from "astro:assets";
import Logo from "@assets/images/logo.png";
---

<div class="fixed top-0 left-0 w-full z-50">
    
    <div class="absolute inset-0 h-full bg-white mask-[linear-gradient(to_bottom,black_70%,transparent_100%)] -z-10"></div>

    <nav class="flex justify-between items-center px-12 pt-2 pb-3">

    <div class="flex items-center gap-12">
        <a href="/">
            <Image
                src={Logo}
                alt="Logo Binding Software"
                class="h-20 w-auto object-contain shrink-0"
            />
        </a>
        <ul class="flex items-center gap-8">
            <li>
                <a
                    href="/"
                    class="text-black hover:text-purple-800 text-xs font-semibold uppercase tracking-widest transition-colors"
                    >Inicio</a
                >
            </li>
            <li class="group relative py-5"> 
                <a
                    href="#"
                    class="text-black hover:text-purple-800 text-xs font-semibold uppercase tracking-widest transition-colors"
                >
                    Soluciones
                </a>
            
                <ul
                    class="absolute left-0 top-full w-56 bg-white shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 rounded-xl py-2 border border-gray-100 z-100 overflow-visible"
                >
                    <li class="relative">
                        <a href="#" class="block px-5 py-3 text-[11px] text-gray-700 hover:text-purple-800 hover:bg-purple-50 uppercase font-bold tracking-wider transition-colors">
                            Binding Identity
                        </a>
                    </li>
                    <li class="relative">
                        <a href="#" class="block px-5 py-3 text-[11px] text-gray-700 hover:text-purple-800 hover:bg-purple-50 uppercase font-bold tracking-wider transition-colors">
                            Binding Phone
                        </a>
                    </li>
                    <li class="relative">
                        <a href="#" class="block px-5 py-3 text-[11px] text-gray-700 hover:text-purple-800 hover:bg-purple-50 uppercase font-bold tracking-wider transition-colors">
                            Binding Consulting
                        </a>
                    </li>
                </ul>
            </li>

            <li>
                <a
                    href="/"
                    class="text-black hover:text-purple-800 text-xs font-semibold uppercase tracking-widest transition-colors"
                    >Partners</a
                >
            </li>
            <li>
                <a
                    href="/"
                    class="text-black hover:text-purple-800 text-xs font-semibold uppercase tracking-widest transition-colors"
                    >Training</a
                >
            </li>
            <li>
                <a
                    href="/"
                    class="text-black hover:text-purple-800 text-xs font-semibold uppercase tracking-widest transition-colors"
                    >I+D+i</a
                >
            </li>
            <li>
                <a
                    href="/"
                    class="text-black hover:text-purple-800 text-xs font-semibold uppercase tracking-widest transition-colors"
                    >Media</a
                >
            </li>
            <li>
                <a
                    href="/"
                    class="text-black hover:text-purple-800 text-xs font-semibold uppercase tracking-widest transition-colors"
                    >Contacto</a
                >
            </li>
        </ul>
    </div>

    <div class="flex items-center gap-8">
        <div
            class="flex items-center gap-2 text-[10px] font-bold uppercase tracking-widest text-gray-400"
        >
            <a
                href="?lang=es"
                class="text-gray-900 border-b border-gray-900 pb-0.5">ES</a
            >
            <span class="opacity-30">|</span>
            <a href="?lang=en" class="hover:text-gray-900 transition-colors"
                >EN</a
            >
        </div>
        <button
            class="relative inline-flex h-13 w-48 overflow-hidden rounded-full p-0.5 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-slate-50 transition-transform hover:scale-105 active:scale-95 shadow-2xl"
        >
            <span
                class="absolute inset-[-1000%] animate-[spin_6s_linear_infinite]  bg-[conic-gradient(from_90deg_at_50%_50%,#7c3aed_0%,#4f46e5_30%,#2563eb_60%,#1e3a8a_100%)] "
            ></span>

            <span
                class="inline-flex h-full w-full cursor-pointer items-center justify-center rounded-full bg-slate-950/80 px-4 py-2 text-sm font-medium text-white backdrop-blur-3xl"
            >
                <p
                    class="m-0 p-0 text-center text-sm font-bold tracking-widest uppercase"
                >
                    Iniciar Sesión
                </p>
            </span>
        </button>
    </div>
</nav>

