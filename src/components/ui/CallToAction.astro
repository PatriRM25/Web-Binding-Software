<section
    class="relative w-full flex flex-col py-24 items-center text-center justify-center bg-gray-900 overflow-hidden lg:min-h-[60vh]"
    id="cta"
>
    
    <div
        class="absolute top-1/2 left-[25%] lg:left-[35%] transform -translate-x-1/2 -translate-y-1/2 w-40 h-40 lg:w-96 lg:h-96 bg-purple-600 rounded-full z-0 mix-blend-screen filter blur-3xl opacity-40"
    >
    </div>
    

    <div
        class="flex flex-col items-center justify-center relative z-40 container mx-auto px-6"
    >
        <p class="text-gray-300 text-base md:text-lg mb-4 tracking-wide">
            Revoluciona tu hotel con tecnología de vanguardia
        </p>

        <div
            class="flex flex-wrap justify-center items-center gap-2 text-2xl md:text-4xl lg:text-5xl font-bold text-white
               min-h-10 md:min-h-14 lg:min-h-16"
        >
            <span>Transforma tu hotel con</span>
            <span id="typing-container" class="text-purple-400 inline-flex"
            ></span>
            <span
                class="inline-block w-1 h-8 md:h-12 bg-purple-500 animate-pulse ml-1"
            ></span>
        </div>

        <button
            type="button"
            class="relative mt-12 inline-flex h-16 w-48 overflow-hidden rounded-full p-0.5 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-slate-50 transition-transform hover:scale-105 active:scale-95 shadow-2xl"
        >
            <span
                class="absolute inset-[-1000%] animate-[spin_6s_linear_infinite] bg-[conic-gradient(from_90deg_at_50%_50%,#7c3aed_0%,#4f46e5_30%,#2563eb_60%,#1e3a8a_100%)] opacity-100"
            ></span>
            <span
                class="inline-flex h-full w-full cursor-pointer items-center justify-center rounded-full bg-slate-950/80 px-4 py-2 text-sm font-medium text-white backdrop-blur-3xl"
            >
                <p
                    class="m-0 p-0 text-center text-sm font-bold tracking-widest uppercase"
                >
                    Contactar
                </p>
            </span>
        </button>
    </div>
</section>

<script>
    import { animate, stagger, inView } from "motion";

    const phraseStatic = "Transforma tu hotel con";
    const phraseDynamic = "Binding Software.";

    const staticContainer = document.querySelector(
        ".flex.flex-wrap span:first-child",
    );
    const dynamicContainer = document.getElementById("typing-container");

    if (staticContainer && dynamicContainer) {

        staticContainer.textContent = "";

       
        const createSpans = (text: string, target: HTMLElement) => {
            return text.split("").map((char) => {
                const span = document.createElement("span");
                span.textContent = char === " " ? "\u00A0" : char;
                span.style.opacity = "0";
                span.style.display = "inline-block";
                target.appendChild(span);
                return span;
            });
        };

       
        const spansStatic = createSpans(
            phraseStatic,
            staticContainer as HTMLElement,
        );
        const spansDynamic = createSpans(phraseDynamic, dynamicContainer);

        
        const allSpans = [...spansStatic, ...spansDynamic];

        inView(staticContainer, () => {
            const runSequence = async () => {
                await animate(
                    allSpans,
                    { opacity: [0, 1], y: [10, 0] },
                    { delay: stagger(0.05), duration: 0.2 },
                ).finished;

                 await new Promise((r) => setTimeout(r, 2000));
                while (true) {
                    
                    await animate(
                        spansDynamic,
                        { opacity: 0 },
                        {
                            delay: stagger(0.04, { from: "last" }),
                            duration: 0.1,
                        },
                    ).finished;

                    await new Promise((r) => setTimeout(r, 500));

                    
                    await animate(
                        spansDynamic,
                        { opacity: 1 },
                        { delay: stagger(0.08), duration: 0.2 },
                    ).finished;

                    await new Promise((r) => setTimeout(r, 3000));
                }
            };

            runSequence();
        });
    }
</script>
