---
import { Image } from "astro:assets";
import imagenCheckIn from "@assets/images/check-in.png";
import imagenSupport from "@assets/images/support.png";
import imagenConsulting from "@assets/images/consulting.png";



const soluciones = [
    {
        titulo: "Binding Identity",
        descripcion: "Utiliza el rápido Check-in All in One, el único nativo digital para identidades electrónicas. Binding Identity es el único sistema de fastChek-in All in One digital del mercado.",
        imagen: imagenCheckIn,
        color: "from-[#7f4790] to-[#3977b4]"
    },
    {
        titulo: "Binding Phone",
        descripcion: "La solución permite: mejorar la experiencia cliente, maximizar la productividad y  optimizar los tiempos de  atención al cliente mejorando la productividad de los agentes destinados a este servicio.",
        imagen: imagenSupport,
        color: "from-cyan-500 to-blue-600"
    },
    {
        titulo: "Binding Consulting",
        descripcion: " Desde Binding Software usamos como hilo conductor al cliente del hotel y las necesidades que genera en los servicios que se ofrecen desde el hotel. Podemos ayudar en todos y cada  uno de los procesos de negocio, mediante servicios de consultoría de negocio y tecnológica.",
        imagen: imagenConsulting,
        color: "from-purple-500 to-indigo-600"
    }
];
---

<section class="reveal opacity-0 w-full max-w-7xl mx-auto px-6 py-16 md:py-24 pt-40 pb-40">
    <div class="mb-16 text-center ">
        <h1 class="  font-avenir font-bold text-4xl md:text-6xl tracking-tight bg-linear-to-r from-[#7f4790] to-[#3977b4] bg-clip-text text-transparent inline-block pb-5 ">
            Nuestras Soluciones
        </h1>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {soluciones.map((solucion) => (
            <div class="group relative bg-white border border-slate-100 rounded-3xl p-8 hover:shadow-[0_30px_60px_-15px_rgba(0,0,0,0.1)] transition-all duration-500 flex flex-col h-full overflow-hidden">
                
                <div class="absolute -top-24 -right-24 w-48 h-48 bg-linear-to-br from-cyan-500/10 to-purple-500/10 blur-3xl rounded-full group-hover:scale-150 transition-transform duration-700"></div>

                <div class="relative w-full aspect-square mb-6 flex items-center justify-center">
                    <div class="relative w-full h-full transform transition-transform duration-500 group-hover:scale-110 group-hover:-translate-y-2">
                        <Image
                            src={solucion.imagen}
                            alt={solucion.titulo}
                            width={400}
                            height={400}
                            format="avif"
                            class="w-full h-full object-contain drop-shadow-[0_10px_30px_rgba(8,112,184,0.2)]"
                        />
                    </div>
                </div>

                <div class="relative space-y-4 grow">
                    <h2 class={`text-2xl font-bold tracking-tight bg-linear-to-r ${solucion.color} bg-clip-text text-transparent`}>
                        {solucion.titulo}
                    </h2>
                    <p class="text-slate-600 leading-relaxed text-sm md:text-base">
                        {solucion.descripcion}
                    </p>
                </div>

                <div class="relative pt-6">
                    <a href="#" class="inline-flex items-center text-sm font-bold text-cyan-600 hover:text-cyan-700 group/btn">
                        Saber más 
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1 transform group-hover/btn:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                    </a>
                </div>
            </div>
        ))}
    </div>
</section>

<script>
    import { animate, inView, stagger } from "motion";

    
    const sections = document.querySelectorAll(".reveal");

    sections.forEach((section) => {
        
        inView(section, (el) => {
            
            const target = section as HTMLElement;
            animate(
                target,
                { opacity: [0, 1], y: [30, 0] },
                { duration: 1, easing: "ease-out" } as any
            );

            const cards = target.querySelectorAll(".group");
            if (cards.length > 0) {
                animate(
                    cards,
                    { opacity: [0, 1], scale: [0.95, 1], y: [20, 0] },
                    { 
                        delay: stagger(0.15), 
                        duration: 0.5, 
                        easing: "ease-out" 
                    } as any
                );
            }
        });
    });
</script>